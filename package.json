{
  "name": "site-tools",
  "private": true,
  "devDependencies": {
    "html-validate": "^9.7.1",
    "remark-cli": "^12.0.1",
    "remark-lint-list-item-indent": "^3.1.2",
    "remark-preset-lint-recommended": "^6.1.3",
    "stylelint": "^17.4.0",
    "stylelint-config-recommended-scss": "^17.0.0",
    "stylelint-scss": "^7.0.0"
  },
  "scripts": {
    "lint:scss": "stylelint \"assets/**/*.scss\" --allow-empty-input --ignore-pattern \"assets/main.scss\" --custom-syntax postcss-scss",
    "lint:md": "remark -q index.md about.md archive.md _posts/**/*.md",
    "lint:html": "html-validate --config .htmlvalidate.json _layouts/**/*.html _includes/**/*.html *.html",
    "lint": "pnpm run lint:scss && pnpm run lint:md && pnpm run lint:html"
  }
}
